{
  "builds": [
    {
      "src": "exampleSite/**/*",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "public"
      }
    }
  ],
  "functions": {},
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "regions": ["hkg1"],
  "name": "webstack-hugo"
}
{
  "version": 2,
  "builds": [
    {
      "src": "layouts/**/*",
      "use": "@vercel/static-build",
      "config": {
        "distDir": ".",
        "command": "hugo"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "regions": ["hkg1"],
  "name": "webstack-hugo"
}